# Copy this to .env and fill in real values. Never commit .env.

# Your domain, pointed at the VM's IP via an A record (required for Telegram HTTPS webhook)
DOMAIN=agent.example.com
ACME_EMAIL=you@example.com

# n8n
N8N_ENCRYPTION_KEY=   # generate with: openssl rand -hex 32
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=  # generate with: openssl rand -hex 16

# App Postgres (projects, tasks, conversation_log)
POSTGRES_USER=agent
POSTGRES_PASSWORD=  # generate with: openssl rand -hex 16
POSTGRES_DB=agent

# RunPod (Phase 2 — router + local LLM, serverless vLLM endpoints)
RUNPOD_API_KEY=
RUNPOD_ROUTER_ENDPOINT_ID=guadc1rxe929r4   # Qwen2.5-3B-Instruct, classifies each message
RUNPOD_LOCAL_MODEL_ENDPOINT_ID=d902gj6z3zpe21   # Qwen2.5-14B-Instruct (unquantized), handles non-English "simple" replies + future heavier local tasks
RUNPOD_EMBEDDING_ENDPOINT_ID=954od6235588eo     # multilingual-e5-small (384-dim), for Qdrant RAG in Phase 3

# HuggingFace (needed by the embedding endpoint template — anonymous downloads get rate-limited on shared RunPod IPs)
HF_TOKEN=
